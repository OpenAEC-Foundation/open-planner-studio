        { "name": "Schilderwerk", "dur": 6, "code": { "Fase": "Afbouw" }, "assign": [{ "res": "Ploeg B", "units": 1 }] }
      ],
      "expect": {},
      "view": {
        "filter": { "field": { "code": "Fase" }, "operator": "eq", "value": "Ruwbouw" },
