{
  "name": "open-planner-studio",
  "private": true,
  "version": "2026.2.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:3007 && cross-env VITE_DEV_SERVER_URL=http://localhost:3007 electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:start": "cross-env VITE_DEV_SERVER_URL=http://localhost:3007 electron ."
  },
  "dependencies": {
    "i18next": "^25.8.13",
    "immer": "^11.1.4",
    "lucide-react": "^0.575.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.5.4",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "autoprefixer": "^10.4.0",
    "concurrently": "^9.0.0",
    "cross-env": "^7.0.3",
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.5.0",
    "vite": "^7.3.1",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "org.openaec.planner",
    "productName": "Open Planner Studio",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm"],
      "icon": "public/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "public/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": true,
      "allowToChangeInstallationDirectory": true
    }
  }
}
