{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Open Planner Studio",
  "version": "2026.2.0",
  "identifier": "org.openaec.planner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3007",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Open Planner Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": { "open": true },
    "fs": {}
  }
}
