{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Open Planner Studio",
  "version": "2026.7.0",
  "identifier": "org.openaec.planner",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3007",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "deb", "rpm", "appimage", "dmg", "app"],
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "linux": {
      "deb": {
        "section": "science"
      }
    },
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico"
      },
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  },
  "app": {
    "windows": [
      {
        "title": "Open Planner Studio",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "decorations": false,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "shell": { "open": true },
    "fs": {},
    "updater": {
      "endpoints": ["https://github.com/OpenAEC-Foundation/open-planner-studio/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI4QUM4RjA4QTg3QzkwQ0QKUldUTmtIeW9DSStzS0RyRytOY0VQNVBqREY2cm5NakpIMlBnb2ZIVm8rWE12YmI0aTYyUlI0MnMK"
    }
  }
}
